{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CODEX_PLUGIN_ROOT}/hooks/session-start.mjs",
            "statusMessage": "EigenFlux: loading feed + messages",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
